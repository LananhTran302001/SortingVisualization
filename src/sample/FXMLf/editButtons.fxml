<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="65.0" stylesheets="@../CSS/EditButtons.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Button cancelButton="true" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" prefHeight="28.0" prefWidth="36.0" stylesheets="@../CSS/EditButtons.css">
            <tooltip>
                <Tooltip text="Stop" />
            </tooltip>
            <graphic>
                <ImageView fitHeight="29.0" fitWidth="27.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@../image/pauseIcon.png" />
                </ImageView>
            </graphic>
            <HBox.margin>
                <Insets left="35.0" right="10.0" />
            </HBox.margin>
         <padding>
            <Insets bottom="7.0" left="7.0" right="7.0" top="5.0" />
         </padding>
        </Button>
        <Button fx:id="playButton" cancelButton="true" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" prefHeight="28.0" prefWidth="36.0" stylesheets="@../CSS/EditButtons.css">
            <graphic>
                <ImageView fitHeight="29.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../image/playIcon.png" />
                </ImageView>
            </graphic>
            <tooltip>
                <Tooltip text="Sort" />
            </tooltip>
            <HBox.margin>
                <Insets right="5.0" />
            </HBox.margin>
         <padding>
            <Insets bottom="7.0" left="7.0" right="7.0" top="5.0" />
         </padding>
        </Button>
        <TextField fx:id="textField" maxWidth="800.0" prefHeight="35.0" prefWidth="800.0" promptText="Enter list of numbers seperated by space" stylesheets="@../CSS/EditButtons.css">
            <cursor>
                <Cursor fx:constant="TEXT" />
            </cursor>
            <HBox.margin>
                <Insets left="15.0" right="25.0" />
            </HBox.margin>
            <font>
                <Font size="15.0" />
            </font>
        </TextField>
        <Button fx:id="makingListButton" layoutX="401.0" layoutY="10.0" mnemonicParsing="false" stylesheets="@../CSS/EditButtons.css">
            <graphic>
                <ImageView fitHeight="28.0" fitWidth="30.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../image/okIcon.png" />
                </ImageView>
            </graphic>
            <HBox.margin>
                <Insets right="25.0" />
            </HBox.margin>
            <cursor>
                <Cursor fx:constant="DEFAULT" />
            </cursor>
            <tooltip>
                <Tooltip text="Make a new list" />
            </tooltip>
         <padding>
            <Insets bottom="7.0" left="8.0" right="8.0" top="6.0" />
         </padding>
        </Button>
      <Button fx:id="randomButton" layoutX="410.0" layoutY="25.0" mnemonicParsing="false" stylesheets="@../CSS/EditButtons.css">
         <graphic>
            <ImageView fitHeight="32.0" fitWidth="32.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../image/randomIcon.png" />
               </image>
            </ImageView>
         </graphic>
         <cursor>
            <Cursor fx:constant="DEFAULT" />
         </cursor>
         <tooltip>
            <Tooltip text="Random" />
         </tooltip>
         <HBox.margin>
            <Insets right="25.0" />
         </HBox.margin>
      </Button>
        <Button fx:id="additionButton" mnemonicParsing="false" prefHeight="28.0" prefWidth="28.0" stylesheets="@../CSS/EditButtons.css">
            <graphic>
                <ImageView fitHeight="25.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../image/addIcon.png" />
                </ImageView>
            </graphic>
            <HBox.margin>
                <Insets right="25.0" />
            </HBox.margin>
            <cursor>
                <Cursor fx:constant="DEFAULT" />
            </cursor>
            <tooltip>
                <Tooltip text="Add " wrapText="true" />
            </tooltip>
         <padding>
            <Insets bottom="7.0" left="7.0" right="7.0" top="7.0" />
         </padding>
        </Button>
        <MenuButton fx:id="deleteButton" mnemonicParsing="false" stylesheets="@../CSS/EditButtons.css">
            <items>
                <MenuItem mnemonicParsing="false" text="Delete" />
                <MenuItem mnemonicParsing="false" text="Delete all" />
            </items>
            <graphic>
                <ImageView fitHeight="27.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                    <Image url="@../image/trashIcon.png" />
                </ImageView>
            </graphic>
            <tooltip>
                <Tooltip text="Delete" />
            </tooltip>
            <HBox.margin>
                <Insets right="15.0" />
            </HBox.margin>
         <padding>
            <Insets bottom="3.0" left="1.0" right="1.0" top="1.0" />
         </padding>
        </MenuButton>
    </children>
   <padding>
      <Insets top="15.0" />
   </padding>
   
</HBox>
