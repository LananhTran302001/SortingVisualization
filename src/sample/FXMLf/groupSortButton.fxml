<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="394.0" prefWidth="170.0" style="-fx-background-color: #4f4f5f;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1">
   <children>
       <ToggleButton fx:id="bubbleSButton" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../CSS/GroupSortButton.css" text="Bubble Sort">
           <cursor>
               <Cursor fx:constant="HAND" />
           </cursor>
           <font>
               <Font size="13.0" />
           </font>
           <VBox.margin>
               <Insets bottom="15.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
       </ToggleButton>
       <ToggleButton fx:id="selectionSButton" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../CSS/GroupSortButton.css" text="Selection Sort" textFill="WHITE">
           <cursor>
               <Cursor fx:constant="DEFAULT" />
           </cursor>
           <font>
               <Font size="13.0" />
           </font>
           <VBox.margin>
               <Insets bottom="15.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
       </ToggleButton>
       <ToggleButton fx:id="insertionSButton" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../CSS/GroupSortButton.css" text="Insertion Sort" textFill="WHITE">
           <cursor>
               <Cursor fx:constant="DEFAULT" />
           </cursor>
           <font>
               <Font size="13.0" />
           </font>
           <VBox.margin>
               <Insets bottom="15.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
       </ToggleButton>
       <ToggleButton fx:id="mergeSButton" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../CSS/GroupSortButton.css" text="Merge Sort" textFill="WHITE">
           <cursor>
               <Cursor fx:constant="HAND" />
           </cursor>
           <font>
               <Font size="13.0" />
           </font>
           <VBox.margin>
               <Insets bottom="15.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
       </ToggleButton>
       <ToggleButton fx:id="heapSButton" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../CSS/GroupSortButton.css" text="Heap Sort" textFill="WHITE">
           <cursor>
               <Cursor fx:constant="HAND" />
           </cursor>
           <font>
               <Font size="13.0" />
           </font>
           <VBox.margin>
               <Insets bottom="15.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
       </ToggleButton>
       <ToggleButton fx:id="quickSButton" contentDisplay="CENTER" mnemonicParsing="false" stylesheets="@../CSS/GroupSortButton.css" text="Quick Sort" textFill="WHITE">
           <cursor>
               <Cursor fx:constant="HAND" />
           </cursor>
           <font>
               <Font size="13.0" />
           </font>
           <VBox.margin>
               <Insets bottom="15.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
       </ToggleButton>
       <Label fx:id="tiltleSpeed" text="Speed" textFill="WHITE">
           <VBox.margin>
               <Insets bottom="5.0" left="25.0" right="10.0" top="10.0" />
           </VBox.margin>
           <font>
               <Font size="13.0" />
           </font>
       </Label>
       <Slider fx:id="speedSlider" blockIncrement="20.0" maxWidth="300.0" min="20.0" prefHeight="14.0" prefWidth="100.0" stylesheets="@../CSS/GroupSortButton.css">
           <VBox.margin>
               <Insets bottom="10.0" left="20.0" right="20.0" />
           </VBox.margin>
       </Slider>
   </children>
</VBox>
